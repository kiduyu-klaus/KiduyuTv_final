<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Full-bleed backdrop -->
    <ImageView
        android:id="@+id/detailBackdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.25"
        android:contentDescription="@null" />

    <!-- Dark gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/detail_full_scrim" />

    <!-- Main scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="72dp"
            android:paddingBottom="48dp">

            <!-- Hero row: poster + info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:gravity="top">

                <!-- Poster -->
                <ImageView
                    android:id="@+id/detailPoster"
                    android:layout_width="160dp"
                    android:layout_height="240dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/card_bg"
                    android:elevation="8dp"
                    android:contentDescription="@null" />

                <!-- Info column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="32dp"
                    android:paddingTop="4dp">

                    <TextView
                        android:id="@+id/detailTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.1" />

                    <!-- Meta row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:id="@+id/detailYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <View
                            android:layout_width="4dp"
                            android:layout_height="4dp"
                            android:background="#555555"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp" />

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/rating_pill">

                            <TextView
                                android:id="@+id/detailRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:textColor="@color/rating_gold"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/detailTypeBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/detailOverview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.5"
                        android:maxLines="5"
                        android:ellipsize="end" />

                    <Button
                        android:id="@+id/btnPlay"
                        android:layout_width="180dp"
                        android:layout_height="48dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/btn_play_bg"
                        android:text="@string/play_now"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:focusable="true"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnProvider"
                        android:layout_width="220dp"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/back_btn_bg"
                        android:focusable="true"
                        android:letterSpacing="0.03"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </LinearLayout>

            <!-- TV: Season selector -->
            <LinearLayout
                android:id="@+id/seasonRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:paddingTop="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/season"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/btnSeasonPrev"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/season_nav_btn"
                    android:gravity="center"
                    android:text="@string/season_previous_symbol"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:focusable="true"
                    android:clickable="true" />

                <TextView
                    android:id="@+id/tvSeasonCurrent"
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/season_display_bg"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/btnSeasonNext"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/season_nav_btn"
                    android:gravity="center"
                    android:text="@string/season_next_symbol"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:focusable="true"
                    android:clickable="true" />

                <TextView
                    android:id="@+id/tvSeasonCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginStart="16dp" />

            </LinearLayout>

            <!-- Episode list label -->
            <TextView
                android:id="@+id/labelEpisodes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp"
                android:text="@string/episodes"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:visibility="gone" />

            <TextView
                android:id="@+id/detailStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/back_btn_bg"
                android:paddingStart="24dp"
                android:paddingTop="12dp"
                android:paddingEnd="24dp"
                android:paddingBottom="12dp"
                android:text="@string/loading_titles"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEpisodes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:clipToPadding="false"
                android:focusable="true"
                android:descendantFocusability="afterDescendants"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- Back button -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="20dp"
        android:background="@drawable/back_btn_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:text="@string/back"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:focusable="true"
        android:clickable="true" />

</FrameLayout>
